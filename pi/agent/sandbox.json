{
  "enabled": true,
  "comment": "Read anywhere (except blocklist), Write only in cwd and subdirectories",
  "network": {
    "allowedDomains": [
      "*.com", "*.org", "*.net", "*.io", "*.dev", "*.co", "*.ai",
      "*.app", "*.cloud", "*.run", "*.sh", "*.xyz", "*.tech", "*.tools",
      "*.so", "*.me", "*.us", "*.uk", "*.eu", "*.de", "*.fr", "*.it",
      "*.edu", "*.gov", "*.info", "*.cc", "*.ly", "*.dev", "*.new",
      "localhost", "127.0.0.1", "::1"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": [
      "~/.ssh",
      "~/.aws",
      "~/.gnupg",
      "~/.npmrc",
      "~/.config/gh/hosts.yml",
      "~/.gitconfig",
      ".env",
      "~/.pi/auth.json",
      "~/.pi/models.json"
    ],
    "allowWrite": ["."],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key",
      "id_rsa",
      "id_ed25519",
      ".pi/extensions"
    ]
  }
}
